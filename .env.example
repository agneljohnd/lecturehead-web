# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# ── SEO indexing guard ──────────────────────────────────────────────
# Leave UNSET (or false) on local, preview, and *.vercel.app deploys.
# Set to "true" ONLY on the real production domain (lecturehead.com)
# so search engines index the real site and nothing else.
NEXT_PUBLIC_ENABLE_INDEXING=

# ── Analytics ───────────────────────────────────────────────────────
# Google Analytics measurement ID. Inlined at build time.
NEXT_PUBLIC_GA_ID=

# ── Admin / Playbook publisher (only needed for /admin) ─────────────
ADMIN_PASSWORD=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
ANTHROPIC_API_KEY=

# ── IndexNow (optional — instant search-engine pings) ───────────────
INDEXNOW_KEY=
